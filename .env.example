# === Core Gemini Configuration ===
GEMINI_API_KEY=your_api_key_here
MODEL_ID=gemini-3.1-flash-image-preview

# === Mac Testing (labs/brain_mac.py) ===
# Index for sounddevice (Run `uv run python -m sounddevice` to find yours)
DEVICE_INDEX=3

# === Raspberry Pi (brain.py) ===
# The ALSA hardware device for the USB Microphone
# (Run `arecord -l` on the Pi to verify)
MIC_HW=plughw:2,0

# (Run `aplay -l` on the Pi to verify)
SPEAKER_HW=plughw:0,0

# === Inky Impression ===
# 0.0 to 1.0 (default is 0.5)
INKY_SATURATION=0.5
